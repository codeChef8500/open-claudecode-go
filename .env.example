# Agent Engine 环境变量配置
# 复制此文件为 .env 并填入你的真实密钥
# cp .env.example .env

# ── 方式1: 通用配置 (推荐) ─────────────────────────────────
AGENT_ENGINE_PROVIDER=openai
AGENT_ENGINE_MODEL=MiniMax-M2.5
AGENT_ENGINE_API_KEY=sk-your-api-key-here
AGENT_ENGINE_BASE_URL=https://your-api-endpoint/v1

# ── 方式2: OpenAI 兼容 API ────────────────────────────────
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── 方式3: Anthropic 原生 ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxx

# ── 方式4: VLLM / ARK ────────────────────────────────────
# VLLM_API_KEY=your-key
# VLLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ── 方式5: MiniMax 直连 ──────────────────────────────────
# MINIMAX_API_KEY=your-key
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ── 方式6: OpenRouter ────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-xxx

# ── 搜索 Provider (可选) ─────────────────────────────────
# 默认使用 DuckDuckGo（免费但会被限流/CAPTCHA）
# 推荐配置 Brave Search API（免费 2000 次/月）
# 申请: https://brave.com/search/api/
# AGENT_ENGINE_SEARCH_API_KEY=BSA-xxx
# AGENT_ENGINE_SEARCH_PROVIDER=brave
# 或直接用 Brave 专用变量:
# BRAVE_SEARCH_API_KEY=BSA-xxx

# ── 权限模式 (可选) ──────────────────────────────────────
# AGENT_ENGINE_PERMISSION_MODE=default
# 可选值: default, auto, bypass, plan, acceptEdits, dontAsk
